# SupplyRadar — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Firebase ───────────────────────────────────────────────────────────────
# Firebase Web API Key (from Project Settings → General)
FIREBASE_API_KEY=your_firebase_web_api_key_here
# Firebase Project ID
FIREBASE_PROJECT_ID=your_project_id_here
# Path to service account JSON (for Firestore Admin SDK)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── News APIs ─────────────────────────────────────────────────────────────
# Free at: https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here
# Free at: https://open-platform.theguardian.com
GUARDIAN_KEY=your_guardian_key_here
# Free at: https://gnews.io (fallback, optional)
GNEWS_KEY=

# ── App Config ────────────────────────────────────────────────────────────
# How often to fetch news (minutes). Free NewsAPI = 100 req/day
FETCH_INTERVAL_MINUTES=15
MAX_ARTICLES_PER_SOURCE=20
# Set to "production" on Streamlit Cloud
ENV=development

# ── Telegram Alerts (optional — Phase 8) ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
